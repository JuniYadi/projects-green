{
  "name": "pfnapp-v2",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "rm -rf .next/",
    "dev": "next dev --turbopack --port 3300",
    "build": "next build",
    "start": "next start",
    "serve": "local-to-pub --port 3300 --uri pgreen",
    "test": "bun test 'test/**/*.test.ts' 'test/**/*.test.tsx' '**/*.test.ts' '**/*.test.tsx'",
    "test:coverage": "bun run scripts/check-coverage-threshold.ts",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "worker:all": "bun run scripts/workers.ts",
    "worker:github": "bun run scripts/github-worker.ts",
    "worker:billing": "bun run scripts/billing-cron.ts",
    "worker:app-hosting-billing": "bun run scripts/app-hosting-billing-worker.ts",
    "worker:whatsapp-billing": "bun run scripts/whatsapp-monthly-billing-worker.ts",
    "worker:github-events-retention": "bun run scripts/github-event-retention-worker.ts",
    "worker:deploy-monitor": "bun run scripts/deploy-monitor-worker.ts",
    "db:generate": "bun --bun prisma generate",
    "db:migrate:dev": "bun --bun prisma migrate dev",
    "db:migrate:deploy": "bun --bun prisma migrate deploy",
    "db:studio": "bun --bun prisma studio",
    "db:status": "bun --bun prisma status",
    "db:pull": "bun --bun prisma db pull --print",
    "github:worker": "bun run scripts/github-worker.ts",
    "seed:all": "bun run scripts/seed-runner.ts --all",
    "seed:system": "bun run scripts/seed-runner.ts --system",
    "seed:dummy": "bun run scripts/seed-runner.ts --dummy",
    "seed:invoices-support-tickets": "bun run scripts/seed-invoices-support-tickets.ts",
    "remediate:creator-tenant-roles": "bun run scripts/remediate-creator-tenant-roles.ts",
    "admin:role": "bun run scripts/admin-role.ts",
    "seed:workos-roles": "node scripts/seed-workos-roles.mjs",
    "bootstrap:super-admin": "bun run scripts/bootstrap-super-admin.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth": "playwright test --project=auth-setup",
    "test:e2e:authenticated": "playwright test --project=authenticated",
    "test:e2e:public": "playwright test --project=chromium",
    "test:e2e:all": "playwright test --project=chromium --project=authenticated",
    "test:auth:cookie": "bun run scripts/test-api-auth-cookie.ts",
    "test:auth:static-key": "bun run scripts/test-api-auth-static-key.ts",
    "create:api-key": "bun run scripts/create-api-key.ts",
    "worker:vpn-renewal": "bun run scripts/vpn-renewal-worker.ts",
    "worker:opensearch-ingest": "bun run scripts/opensearch-ingest-worker.ts",
    "cleanup:webhook-events": "bun run scripts/cleanup-whatsapp-webhook-events.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@elysia/eden": "^1.4.10",
    "@elysia/openapi": "^1.4.15",
    "@faker-js/faker": "^10.4.0",
    "@formatjs/intl-localematcher": "^0.8.8",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opensearch-project/opensearch": "^3.6.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@workos-inc/authkit-nextjs": "^4.1.0",
    "ai": "^6.0.184",
    "bullmq": "^5.76.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elysia": "^1.4.28",
    "js-yaml": "^4.1.1",
    "negotiator": "^1.0.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "ssh2": "^1.17.0",
    "sshpk": "^1.18.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}