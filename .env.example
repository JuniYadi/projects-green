DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pfnapp_v2?schema=public"
REDIS_URL="redis://localhost:6379/0"
QUEUE_PREFIX="pfnapp"
GITHUB_EVENTS_QUEUE_NAME="github-events"
WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_..."
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3300/callback"
# Optional server alias. Keep this equal to NEXT_PUBLIC_WORKOS_REDIRECT_URI.
WORKOS_REDIRECT_URI="http://localhost:3300/callback"
WORKOS_COOKIE_PASSWORD="replace-with-a-random-string-at-least-32-characters-long"
GITHUB_APP_ID=""
GITHUB_APP_SLUG=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
GITHUB_APP_PRIVATE_KEY_BASE64=""
GITHUB_WEBHOOK_SECRET=""
GITHUB_APP_INSTALL_REDIRECT_URI=""
GITHUB_APP_NAME=""
GITHUB_APP_STATE_SECRET=""
FEATURE_GITHUB_APP_INTEGRATION="false"

# Generate ramdom 32-byte base64 key for SUPPORT_TICKET_CONTENT_ENCRYPTION_KEY
# node -e "console.log('base64:' + require('crypto').randomBytes(32).toString('base64'))
SUPPORT_TICKET_CONTENT_ENCRYPTION_KEY="base64:replace-with-32-byte-base64-key"
# Email Configuration (SMTP for Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="notifications@example.com"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="Support <support@yourapp.com>"

NEXT_PUBLIC_APP_URL="http://localhost:3300"

# S3 Storage Configuration (used by support tickets and other features)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_SESSION_TOKEN=""
S3_VIRTUAL_HOSTED_STYLE="false"
S3_PREFIX=""
S3_PRESIGN_TTL_SECONDS="300"
# Attachment settings for file uploads
S3_ATTACHMENT_MAX_SIZE_BYTES="10485760"
S3_ATTACHMENT_ALLOWED_EXTENSIONS="pdf,png,jpg,jpeg,txt,csv,json,log,webp"
# Feature-specific storage prefix override (use S3_PREFIX by default)
SUPPORT_TICKET_ATTACHMENT_S3_PREFIX="support-ticket-attachments"
