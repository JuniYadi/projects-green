generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  NONE
  SUPER_ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformUserRole {
  id           String       @id @default(cuid())
  workosUserId String       @unique
  email        String?      @unique
  role         PlatformRole @default(NONE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model KnowledgeDocument {
  id                    String   @id @default(cuid())
  organizationId        String?
  path                  String
  title                 String
  purpose               String
  howTo                 String[]
  notes                 String[]
  searchText            String
  embedding             Float[]                @default([])
  updatedByWorkosUserId String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, path])
  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model GithubInstallStateNonce {
  id             String   @id @default(cuid())
  nonceHash      String   @unique
  workosUserId   String
  organizationId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([expiresAt])
  @@index([workosUserId])
  @@index([organizationId])
}

model GithubInstallation {
  id                   String   @id @default(cuid())
  githubInstallationId BigInt   @unique
  accountLogin         String
  accountType          String
  targetType           String
  targetId             BigInt?
  workosUserId         String
  organizationId       String?
  status               String   @default("active")
  permissionsJson      Json?
  eventsSubscribed     Json?
  installedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  repositories GithubRepositoryConnection[]

  @@index([workosUserId])
  @@index([organizationId])
  @@index([accountLogin])
}

model GithubRepositoryConnection {
  id                 String   @id @default(cuid())
  githubRepositoryId BigInt
  installationId     String
  fullName           String
  ownerLogin         String
  repoName           String
  defaultBranch      String?
  isPrivate          Boolean
  enabled            Boolean  @default(true)
  branchFilters      String[] @default(["main"])
  rootDirectory      String   @default("/")
  buildConfigJson    Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  installation GithubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([githubRepositoryId, installationId])
  @@index([installationId])
  @@index([fullName])
}

model GithubWebhookEvent {
  id                   String   @id @default(cuid())
  deliveryId           String   @unique
  eventName            String
  action               String?
  githubInstallationId BigInt?
  githubRepositoryId   BigInt?
  payloadJson          Json
  payloadSha256        String
  signatureValid       Boolean
  enqueueStatus        String   @default("queued")
  processStatus        String   @default("pending")
  processError         String?
  receivedAt           DateTime @default(now())
  processedAt          DateTime?

  @@index([eventName])
  @@index([githubInstallationId])
  @@index([githubRepositoryId])
  @@index([processStatus])
}

enum SupportTicketDepartment {
  BILLING
  TECHNICAL
  ACCOUNT
  COMPLIANCE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketService {
  AUTH
  BILLING
  DEPLOY
  DOMAINS
  INTEGRATIONS
  DATA
  OTHER
}

enum SupportTicketAttachmentUploadTarget {
  CREATE
  REPLY
}

enum BillingAccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAUSED
  CANCELED
  ENDED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  CUSTOM
}

enum MeterAggregation {
  SUM
  MAX
  LAST
  COUNT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum InvoiceLineType {
  SUBSCRIPTION
  METERED
  ADJUSTMENT
  TAX
  CREDIT
}

enum InvoiceLineSourceType {
  RATED_USAGE
  ADJUSTMENT
  MANUAL
}

enum BillingAdjustmentType {
  CREDIT
  DEBIT
  WRITEOFF
}

enum BillingRunType {
  RATING
  INVOICING
  FINALIZATION
  RECONCILIATION
}

enum BillingRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum BillingAuditAction {
  CREATED
  UPDATED
  DELETED
  RUN_STARTED
  RUN_FINISHED
  INVOICE_GENERATED
}

enum BillingActorType {
  SYSTEM
  USER
  WORKER
}

model SupportTicket {
  id                        String                  @id @default(cuid())
  ticketNumber              String                  @unique
  organizationId            String
  requesterWorkosUserId     String
  assignedAgentWorkosUserId String?
  department                SupportTicketDepartment
  priority                  SupportTicketPriority
  service                   SupportTicketService?
  status                    SupportTicketStatus     @default(OPEN)
  subject                   String
  description               String?
  secureForm                String?
  attachmentsJson           Json?
  resolvedAt                DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  replies                SupportTicketReply[]
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketConsumedSessions")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@index([requesterWorkosUserId])
  @@index([assignedAgentWorkosUserId])
  @@index([department])
}

model SupportTicketReply {
  id                 String   @id @default(cuid())
  ticketId           String
  authorWorkosUserId String
  body               String
  secureForm         String?
  isInternalNote     Boolean  @default(false)
  attachmentsJson    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ticket                 SupportTicket                        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketReplyConsumedSessions")

  @@index([ticketId, createdAt])
  @@index([authorWorkosUserId])
  @@index([isInternalNote])
}

model SupportTicketAttachmentUploadSession {
  id                 String                              @id
  organizationId     String
  uploaderWorkosUserId String
  target             SupportTicketAttachmentUploadTarget
  ticketId           String?
  fileName           String
  mimeType           String
  sizeBytes          Int
  checksumSha256     String?
  storageKey         String
  storageBucket      String
  expiresAt          DateTime
  registeredAt       DateTime?
  consumedAt         DateTime?
  consumedTicketId   String?
  consumedReplyId    String?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt
  consumedTicket     SupportTicket?                      @relation("SupportTicketConsumedSessions", fields: [consumedTicketId], references: [id], onDelete: SetNull)
  consumedReply      SupportTicketReply?                 @relation("SupportTicketReplyConsumedSessions", fields: [consumedReplyId], references: [id], onDelete: SetNull)

  @@index([organizationId, uploaderWorkosUserId])
  @@index([target, ticketId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model BillingAccount {
  id             String               @id @default(cuid())
  organizationId String               @unique
  currency       String               @default("USD")
  timezone       String               @default("UTC")
  status         BillingAccountStatus @default(ACTIVE)
  metadataJson   Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  subscriptions   BillingSubscription[]
  usageEvents     UsageEvent[]
  ratedUsage      RatedUsage[]
  invoices        Invoice[]
  adjustments     BillingAdjustment[]
  runs            BillingRun[]
  auditLogs       BillingAuditLog[]
}

model BillingSubscription {
  id               String                    @id @default(cuid())
  billingAccountId String
  externalKey      String?
  status           BillingSubscriptionStatus @default(TRIALING)
  startedAt        DateTime
  canceledAt       DateTime?
  endedAt          DateTime?
  metadataJson     Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  versions       SubscriptionVersion[]
  usageEvents    UsageEvent[]
  invoices       Invoice[]

  @@unique([billingAccountId, externalKey])
  @@index([billingAccountId, status])
}

model SubscriptionVersion {
  id              String   @id @default(cuid())
  subscriptionId  String
  planVersionId   String
  version         Int
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  quantity        Decimal  @default(1) @db.Decimal(18, 6)
  metadataJson    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  planVersion  PlanVersion         @relation(fields: [planVersionId], references: [id], onDelete: Restrict)
  ratedUsage   RatedUsage[]

  @@unique([subscriptionId, version])
  @@index([subscriptionId, effectiveFrom(sort: Desc)])
  @@index([planVersionId])
}

model Plan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  metadataJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions PlanVersion[]
}

model PlanVersion {
  id            String        @id @default(cuid())
  planId        String
  version       Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  billingPeriod BillingPeriod
  metadataJson  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  plan                 Plan                  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptionVersions SubscriptionVersion[]
  meterPrices          MeterPrice[]

  @@unique([planId, version])
  @@index([planId, effectiveFrom(sort: Desc)])
}

model Meter {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  eventName    String
  valueKey     String?
  aggregation  MeterAggregation
  isActive     Boolean          @default(true)
  metadataJson Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  meterPrices MeterPrice[]
  usageEvents UsageEvent[]

  @@index([eventName])
}

model MeterPrice {
  id            String   @id @default(cuid())
  meterId        String
  planVersionId  String
  currency       String   @default("USD")
  unitPrice      Decimal  @db.Decimal(18, 6)
  includedUnits  Decimal  @default(0) @db.Decimal(18, 6)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meter       Meter       @relation(fields: [meterId], references: [id], onDelete: Cascade)
  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  ratedUsage  RatedUsage[]

  @@unique([meterId, planVersionId, effectiveFrom])
  @@index([meterId, planVersionId])
}

model UsageEvent {
  id             String   @id @default(cuid())
  billingAccountId String
  subscriptionId String?
  meterId        String
  eventTimestamp DateTime
  quantity       Decimal  @db.Decimal(18, 6)
  idempotencyKey String
  source         String?
  externalEventId String?
  payloadJson    Json?
  createdAt      DateTime @default(now())

  billingAccount BillingAccount        @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription   BillingSubscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  meter          Meter                 @relation(fields: [meterId], references: [id], onDelete: Restrict)
  ratedUsage     RatedUsage?

  @@unique([billingAccountId, idempotencyKey])
  @@index([billingAccountId, eventTimestamp])
  @@index([subscriptionId, meterId, eventTimestamp])
  @@index([meterId, eventTimestamp])
}

model RatedUsage {
  id                    String   @id @default(cuid())
  usageEventId          String   @unique
  billingAccountId      String
  subscriptionVersionId String?
  meterPriceId          String?
  invoiceLineId         String?
  quantity              Decimal  @db.Decimal(18, 6)
  unitPrice             Decimal  @db.Decimal(18, 6)
  amount                Decimal  @db.Decimal(18, 6)
  currency              String
  ratedAt               DateTime @default(now())
  createdAt             DateTime @default(now())

  usageEvent          UsageEvent            @relation(fields: [usageEventId], references: [id], onDelete: Cascade)
  billingAccount      BillingAccount        @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscriptionVersion SubscriptionVersion?  @relation(fields: [subscriptionVersionId], references: [id], onDelete: SetNull)
  meterPrice          MeterPrice?           @relation(fields: [meterPriceId], references: [id], onDelete: SetNull)
  invoiceLine         InvoiceLine?          @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, ratedAt])
  @@index([invoiceLineId])
  @@index([subscriptionVersionId])
}

model Invoice {
  id              String        @id @default(cuid())
  billingAccountId String
  subscriptionId  String?
  billingRunId    String?
  invoiceNumber   String        @unique
  periodStart     DateTime
  periodEnd       DateTime
  currency        String
  status          InvoiceStatus @default(DRAFT)
  subtotalAmount  Decimal       @default(0) @db.Decimal(18, 6)
  taxAmount       Decimal       @default(0) @db.Decimal(18, 6)
  discountAmount  Decimal       @default(0) @db.Decimal(18, 6)
  totalAmount     Decimal       @default(0) @db.Decimal(18, 6)
  issuedAt        DateTime?
  dueAt           DateTime?
  paidAt          DateTime?
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription   BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingRun     BillingRun?          @relation(fields: [billingRunId], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  adjustments    BillingAdjustment[]

  @@unique([billingAccountId, periodStart, periodEnd])
  @@index([billingAccountId, status])
  @@index([subscriptionId, periodStart])
  @@index([billingRunId])
}

model InvoiceLine {
  id            String          @id @default(cuid())
  invoiceId      String
  lineType       InvoiceLineType
  description    String
  quantity       Decimal         @db.Decimal(18, 6)
  unitPrice      Decimal         @db.Decimal(18, 6)
  amount         Decimal         @db.Decimal(18, 6)
  currency       String
  periodStart    DateTime?
  periodEnd      DateTime?
  metadataJson   Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  invoice     Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sources     InvoiceLineSource[]
  ratedUsage  RatedUsage[]

  @@index([invoiceId])
  @@index([lineType])
}

model InvoiceLineSource {
  id             String                @id @default(cuid())
  invoiceLineId  String
  sourceType     InvoiceLineSourceType
  sourceId       String
  amount         Decimal               @db.Decimal(18, 6)
  metadataJson   Json?
  createdAt      DateTime              @default(now())

  invoiceLine InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)

  @@unique([invoiceLineId, sourceType, sourceId])
  @@index([sourceType, sourceId])
}

model BillingAdjustment {
  id                  String               @id @default(cuid())
  billingAccountId    String
  invoiceId           String?
  adjustmentType      BillingAdjustmentType
  amount              Decimal              @db.Decimal(18, 6)
  currency            String
  reason              String?
  createdByWorkosUserId String?
  appliedAt           DateTime?
  metadataJson        Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, createdAt(sort: Desc)])
  @@index([invoiceId])
}

model BillingRun {
  id               String           @id @default(cuid())
  billingAccountId String?
  runType          BillingRunType
  periodStart      DateTime
  periodEnd        DateTime
  status           BillingRunStatus @default(PENDING)
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  errorMessage     String?
  metadataJson     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  billingAccount BillingAccount? @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
  auditLogs      BillingAuditLog[]

  @@unique([billingAccountId, runType, periodStart, periodEnd])
  @@index([billingAccountId, runType, startedAt(sort: Desc)])
}

// ─── WhatsApp Enums ────────────────────────────────────────────────────────────

enum DeviceStatus {
  ACTIVE
  NON_ACTIVE
}

enum ContactGroupStatus {
  ACTIVE
  INACTIVE
}

enum ContactGroupType {
  STATIC
  DYNAMIC
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

enum TemplateSyncStatus {
  SYNCED
  NOT_SYNCED
  NOT_IN_META
}

enum TemplateMetaStatus {
  APPROVED
  PENDING
  REJECTED
}

enum BroadcastStatus {
  QUEUED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
}

enum BroadcastRecipientStatus {
  QUEUED
  SENT
  FAILED
}

enum MessageDirection {
  INBOX
  OUTBOX
}

enum MessageDeliveryStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum BillingCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SERVICE
}

enum BillingStatus {
  CHARGED_PENDING_VERIFY
  CONFIRMED
  REVERTED_FAILED
}

enum LogType {
  INFO
  ERROR
  INBOX
  AUDIT
}

enum ApiKeyEnvironment {
  SANDBOX
  LIVE
}

// ─── WhatsApp Models ──────────────────────────────────────────────────────────

model Device {
  id                         String       @id @default(cuid())
  organizationId             String
  phoneNumber                String       @unique
  balance                    Decimal      @default(0) @db.Decimal(12, 2)
  quotaBase                  Decimal      @default(1000) @db.Decimal(12, 2)
  quotaBaseIn               Int          @default(0)
  quotaBaseOut               Int          @default(0)
  dailyLimitMessage         Int          @default(0)
  rates                      String?
  status                     DeviceStatus @default(ACTIVE)
  token                      String
  s3Path                     String?
  whatsappBusinessAccountId  String?
  whatsappPhoneId            String?
  whatsappApplicationId      String?
  whatsappVersion            String       @default("v24.0")
  whatsappProfile            Json?
  features                   Json?
  callbackUrl                String?
  callbackHeaderName         String?
  callbackHeaderValue        String?
  expiredAt                  DateTime?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  contacts               Contact[]
  contactGroups          ContactGroup[]
  templates              MessageTemplate[]
  broadcastCampaigns     BroadcastCampaign[]
  messageConversations   MessageConversation[]
  dailyCounts            DailyCount[]
  monthlyCounts          MonthlyCount[]
  quotaSessions          QuotaSession[]
  billingLedgers         BillingLedger[]
  logs                   Log[]
  attachments            Attachment[]
  broadcastRateStates     BroadcastRateState[]

  @@index([organizationId])
  @@index([whatsappBusinessAccountId])
}

model ContactGroup {
  id                  String             @id @default(cuid())
  organizationId     String
  name                String             @db.VarChar(100)
  description        String             @db.VarChar(500)
  type                ContactGroupType   @default(STATIC)
  status              ContactGroupStatus @default(ACTIVE)
  throttleMaxMessages Int?
  throttlePerMinutes  Int?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  contacts            Contact[]
  broadcasts          BroadcastCampaign[]
  broadcastRateState BroadcastRateState?

  @@index([organizationId, status])
}

model Contact {
  id              String        @id @default(cuid())
  organizationId  String
  phoneNumber     String        @db.VarChar(20)
  name            String        @db.VarChar(100)
  email           String        @db.VarChar(255)
  status          ContactStatus @default(ACTIVE)
  lastContactedAt DateTime?
  waId            String?
  isWhatsapp      Boolean       @default(false)
  lastCheckedAt   DateTime?
  dynamicValues   Json?
  dynamicRaw      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  contactGroup   ContactGroup @relation(fields: [contactGroupId], references: [id], onDelete: Restrict)
  contactGroupId String

  @@unique([organizationId, phoneNumber])
  @@index([organizationId, contactGroupId, status])
  @@index([organizationId, createdAt])
}

model MessageTemplate {
  id           String              @id @default(cuid())
  organizationId String
  slug         String
  name         String
  description  String?
  syncStatus   TemplateSyncStatus  @default(NOT_SYNCED)
  metaStatus   TemplateMetaStatus?
  lastSyncedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  languages MessageTemplateLanguage[]

  @@index([organizationId, metaStatus])
}

model MessageTemplateLanguage {
  id           String              @id @default(cuid())
  templateId   String
  template     MessageTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  lang         String
  headerType   String?
  headerUrl    String?
  headerText   String?
  body         String?
  parameters   Json?
  footer       String?
  buttons      Json?
  authConfig   Json?
  isApproved   Boolean             @default(false)
  metaStatus   TemplateMetaStatus?
  rejectReason String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([templateId, lang])
}

model BroadcastCampaign {
  id                  String          @id @default(cuid())
  organizationId      String
  templateName        String
  templateLanguage    String
  templateParams      Json?
  throttleMaxMessages Int?
  throttlePerMinutes  Int?
  status              BroadcastStatus @default(QUEUED)
  total               Int             @default(0)
  queued              Int             @default(0)
  sent                Int             @default(0)
  failed              Int             @default(0)
  startedAt           DateTime?
  endedAt             DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  recipients BroadcastRecipient[]

  @@index([organizationId, status])
}

model BroadcastRecipient {
  id            String                   @id @default(cuid())
  broadcastId   String
  broadcast     BroadcastCampaign        @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  phoneNumber   String
  name          String?
  dynamicValues Json?
  status        BroadcastRecipientStatus @default(QUEUED)
  attempts      Int                      @default(0)
  waMessageId   String?
  lastError     String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@unique([broadcastId, phoneNumber])
  @@index([broadcastId, status])
}

model MessageConversation {
  id            String            @id @default(cuid())
  organizationId String
  contactPhone  String
  lastMessageAt DateTime?
  lastDirection MessageDirection?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  messages Message[]

  @@unique([organizationId, contactPhone])
  @@index([organizationId, lastMessageAt])
}

model Message {
  id             String              @id @default(cuid())
  conversationId String
  conversation   MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  fromPhone      String
  contactName    String?
  contactWaId    String?
  content        Json
  waMessageId    String?
  timestamp      DateTime
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  statusHistory MessageStatusHistory[]

  @@index([conversationId, timestamp])
  @@index([waMessageId])
}

model MessageStatusHistory {
  id              String                @id @default(cuid())
  messageId       String
  message         Message               @relation(fields: [messageId], references: [id], onDelete: Cascade)
  status          MessageDeliveryStatus
  errorCode       String?
  errorTitle      String?
  errorMessage    String?
  pricingBillable Boolean?
  pricingCategory String?
  timestamp       DateTime
  createdAt       DateTime              @default(now())

  @@index([messageId, status])
}

model DailyCount {
  id                 String   @id @default(cuid())
  organizationId     String
  date               DateTime @db.Date
  sessionCount       Int      @default(0)
  messageInboxCount  Int      @default(0)
  messageOutboxCount Int      @default(0)
  messageFailedCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([organizationId, date])
}

model MonthlyCount {
  id                 String   @id @default(cuid())
  organizationId     String
  year               Int
  month              Int
  sessionCount       Int      @default(0)
  messageInboxCount  Int      @default(0)
  messageOutboxCount Int      @default(0)
  messageFailedCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([organizationId, year, month])
}

model QuotaSession {
  id           String   @id @default(cuid())
  organizationId String
  phoneNumber   String
  category      String
  expiredAt     DateTime
  createdAt    DateTime @default(now())

  @@index([organizationId, phoneNumber, category])
  @@index([expiredAt])
}

model BillingLedger {
  id              String          @id @default(cuid())
  organizationId  String
  waMessageId     String
  phoneNumber     String
  category        BillingCategory
  quotaKey        String
  quotaValue      Decimal         @db.Decimal(12, 2)
  status          BillingStatus   @default(CHARGED_PENDING_VERIFY)
  isReverted      Boolean         @default(false)
  revertReason    String?
  revertedAt      DateTime?
  lastStatus      String?
  pricingBillable Boolean?
  pricingCategory String?
  errorCode       String?
  errorTitle      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([organizationId, waMessageId])
  @@index([organizationId, status])
  @@index([organizationId, phoneNumber])
}

model Log {
  id        String   @id @default(cuid())
  organizationId String
  source    String
  type      LogType
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([organizationId, type, createdAt])
  @@index([organizationId, source, createdAt])
}

model Attachment {
  id           String   @id @default(cuid())
  organizationId String
  fullPath     String
  originalName String
  newFileName  String
  mimeType     String
  createdAt    DateTime @default(now())

  @@index([organizationId, createdAt])
}

model PricingPackage {
  id                String   @id @default(cuid())
  countryCode       String   @unique
  internationalCode String?
  marketing         Decimal  @db.Decimal(10, 4)
  authentication    Decimal  @db.Decimal(10, 4)
  utility           Decimal  @db.Decimal(10, 4)
  service           Decimal  @db.Decimal(10, 4)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model BroadcastRateState {
  id             String   @id @default(cuid())
  organizationId String
  policy         String   @default("TOKEN_BUCKET")
  lastUpdatedAt  DateTime
  stateData      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model ApiKey {
  id          String            @id @default(cuid())
  name        String
  keyHash     String            @unique
  environment ApiKeyEnvironment
  scopes      String[]
  active      Boolean           @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([environment, active])
}

// ─── WorkOS-tenant relationship ──────────────────────────────────────────────
// organizationId fields above are denormalized WorkOS org IDs.
// No local Organization table — canonical record lives in WorkOS.
// All WhatsApp models scoped by organizationId for multi-tenancy.
