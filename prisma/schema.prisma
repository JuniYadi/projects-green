  status          Int
  createdAt       DateTime @default(now())

  @@index([phoneNumberId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([phoneNumberId, status, createdAt(sort: Desc)])
  @@map("WhatsappApiCall")
}

model WhatsappLog {
  id               String          @id @default(cuid())
  organizationId   String
  type             WhatsappLogType
  message          String
  metadata         Json?
  createdAt        DateTime        @default(now())
  whatsappDevice   WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@index([organizationId, type, createdAt])
}

model WhatsappAttachment {
  id               String          @id @default(cuid())
  organizationId   String
  fileName         String
  mimeType         String
  size             Int
  s3Path           String
  publicUrl        String?
  createdAt        DateTime        @default(now())
  whatsappDevice   WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@index([organizationId, createdAt])
}

model WhatsappBroadcastRateState {
  id                     String               @id @default(cuid())
  organizationId         String
  whatsappContactGroupId String               @unique
  whatsappContactGroup   WhatsappContactGroup @relation(fields: [whatsappContactGroupId], references: [id], onDelete: Cascade)
  lastMessageSentAt      DateTime?
  messagesSentInWindow   Int                  @default(0)
  windowStartAt          DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  whatsappDevice         WhatsappDevice?      @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId       String?

  @@index([organizationId])
}

model WhatsappApiKey {
  id             String                    @id @default(cuid())
  organizationId String
  name           String
  key            String                    @unique
  environment    WhatsappApiKeyEnvironment @default(SANDBOX)
  isActive       Boolean                   @default(true)
  lastUsedAt     DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([organizationId, key])
}

model WhatsappWebhook {
  id               String          @id @default(cuid())
  organizationId   String
  whatsappDeviceId String
  webhookUrl       String
  verifyToken      String
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  whatsappDevice   WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])

  @@index([organizationId])
  @@index([whatsappDeviceId])
}

model WhatsappWebhookDeadLetter {
  id             String    @id @default(cuid())
  organizationId String?
  deviceId       String
  eventType      String
  payloadJson    Json
  errorMessage   String?
  attempts       Int       @default(0)
  status         String    @default("dead_lettered")
  failedAt       DateTime  @default(now())
  replayedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, status])
  @@index([deviceId, status])
  @@index([failedAt(sort: Desc)])
}

model WhatsappWebhookEvent {
  id               String    @id @default(cuid())
  organizationId   String
  whatsappDeviceId String
  eventType        String
  processingStatus String    @default("PENDING")
  metaPayload      Json
  waMessageId      String?
  errorMessage     String?
  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  whatsappDevice WhatsappDevice @relation(fields: [whatsappDeviceId], references: [id])

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([whatsappDeviceId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@index([processingStatus, createdAt(sort: Desc)])
  @@index([waMessageId])
  @@index([createdAt(sort: Desc)])
}

// ─── Payment Models ───────────────────────────────────────────────────────────

model PaymentGateway {
  id                  String   @id @default(cuid())
  name                String
  type                String // "GATEWAY" or "BANK_TRANSFER"
  config              Json // Encrypted JSON: { merchantCode, apiKey, sandboxUrl, productionUrl }
  // ISO currency codes this gateway can settle, e.g. ["IDR"], ["USD"], or both.
  // A gateway is offered when this list includes the account currency.
  supportedCurrencies String[] @default([])
  isActive            Boolean  @default(false)
  isDefault           Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  bankAccounts PaymentBankAccount[]
  invoices     BillingInvoice[]

  @@index([type, isActive])
}

model PaymentBankAccount {
  id                  String   @id @default(cuid())
  gatewayId           String?
  bankCode            String // "BCA", "MANDIRI", "BRI", "BNI"
  bankName            String // "Bank Central Asia"
  accountName         String // AES-256 encrypted
  accountNumber       String // AES-256 encrypted
  // Legacy/default ISO currency code. New filtering uses supportedCurrencies;
  // keep this for backward compatibility and as the primary display currency.
  currency            String   @default("IDR")
  // ISO currency codes this account can receive, e.g. ["IDR"], ["USD"],
  // or both. Manual bank transfer is offered when this list includes the
  // customer's billing currency.
  supportedCurrencies String[] @default([])
  swiftCode           String?
  bankAddress         String?
  isActive            Boolean  @default(true)
  isDefault           Boolean  @default(false)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gateway              PaymentGateway?       @relation(fields: [gatewayId], references: [id])
  paymentConfirmations PaymentConfirmation[]

  @@index([gatewayId, isActive])
  @@index([bankCode])
  @@index([currency, isActive])
  @@map("BankAccount")
}

/// Supported billing currencies and their exchange rate against the base
/// currency (USD). Prices are authored in the base currency; every other
/// currency is derived by multiplying by `ratePerBase`. Exactly one row must
/// have `isBase = true` (its `ratePerBase` is 1).
model PaymentCurrency {
  id             String   @id @default(cuid())
  code           String   @unique // ISO 4217, e.g. "USD", "IDR"
  name           String // "US Dollar", "Indonesian Rupiah"
  symbol         String // "$", "Rp"
  isBase         Boolean  @default(false)
  // Units of this currency per 1 unit of the base currency.
  // USD (base) = 1, IDR = 18000 when 1 USD = 18,000 IDR.
  ratePerBase    Decimal  @default(1) @db.Decimal(18, 6)
  // Top-up bounds expressed in THIS currency.
  minTopup       Decimal  @db.Decimal(18, 2)
  maxTopup       Decimal  @db.Decimal(18, 2)
  // Low-balance warning threshold expressed in THIS currency. The billing UI
  // shows a top-up nudge once the balance drops below this value.
  minBalanceWarn Decimal  @default(0) @db.Decimal(18, 2)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
  @@map("Currency")
}

model PaymentConfirmation {
  id              String    @id @default(cuid())
  invoiceId       String
  bankAccountId   String
  amount          Decimal   @db.Decimal(18, 2)
  paymentDateTime DateTime
  senderBankName  String?
  senderName      String?
  senderAccount   String?
  screenshotUrl   String?
  notes           String?
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  invoice     BillingInvoice     @relation(fields: [invoiceId], references: [id])
  bankAccount PaymentBankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([invoiceId])
  @@index([bankAccountId])
  @@index([status])
  @@index([createdAt])
}

model PaymentAuditLog {
  id         String   @id @default(cuid())
  action     String // "PAYMENT_CREATED", "PAYMENT_CONFIRMED", etc.
  entityType String // "Invoice", "PaymentGateway", etc.
  entityId   String
  actorId    String?
  details    Json
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// ─── Voucher Feature ──────────────────────────────────────────────────────────

/// Status of a voucher: ACTIVE (available), EXPIRED (past expiresAt),
/// DEPLETED (all claims used), DISABLED (manually disabled).
enum VoucherStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  DISABLED
}

model Voucher {
  id                    String        @id @default(cuid())
  code                  String        @unique
  prefix                String?
  status                VoucherStatus @default(ACTIVE)
  maxClaims             Int           @default(1)
  claimedCount          Int           @default(0)
  expiresAt             DateTime
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @default("IDR")
  targetWorkosUserId    String?
  targetOrganizationId  String?
  createdByWorkosUserId String
  metadataJson          Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  claims VoucherClaim[]

  @@index([status, expiresAt])
  @@index([targetWorkosUserId])
  @@index([targetOrganizationId])
  @@index([code, status])
}

model VoucherClaim {
  id                  String   @id @default(cuid())
  voucherId           String
  workosUserId        String
  organizationId      String
  billingAdjustmentId String?
  metadataJson        Json?
  claimedAt           DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, workosUserId])
  @@index([workosUserId, claimedAt(sort: Desc)])
  @@index([voucherId, claimedAt(sort: Desc)])
  @@index([organizationId])
}

model CacheEntry {
  id        String    @id @default(cuid())
  key       String    @unique
  value     String
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([key, expiresAt])
  @@map("CacheEntry")
}
