generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ApiKeyEnvironment {
  SANDBOX
  LIVE
}

enum PlatformRole {
  NONE
  SUPER_ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformUserRole {
  id           String       @id @default(cuid())
  workosUserId String       @unique
  email        String?      @unique
  role         PlatformRole @default(NONE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model ApiKey {
  id          String         @id @default(cuid())
  name        String
  keyHash     String
  environment ApiKeyEnvironment @default(SANDBOX)
  scopes      String[]
  active      Boolean        @default(true)
  expiresAt   DateTime?
  createdBy   String?
  lastUsedAt  DateTime?
  lastUsedIp  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model KnowledgeDocument {
  id                    String   @id @default(cuid())
  organizationId        String?
  path                  String
  title                 String
  purpose               String
  howTo                 String[]
  notes                 String[]
  searchText            String
  embedding             Float[]  @default([])
  updatedByWorkosUserId String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, path])
  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model GithubInstallStateNonce {
  id             String    @id @default(cuid())
  nonceHash      String    @unique
  workosUserId   String
  organizationId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([expiresAt])
  @@index([workosUserId])
  @@index([organizationId])
}

model GithubInstallation {
  id                   String   @id @default(cuid())
  githubInstallationId BigInt   @unique
  accountLogin         String
  accountType          String
  targetType           String
  targetId             BigInt?
  workosUserId         String
  organizationId       String?
  status               String   @default("active")
  permissionsJson      Json?
  eventsSubscribed     Json?
  installedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  repositories GithubRepositoryConnection[]

  @@index([workosUserId])
  @@index([organizationId])
  @@index([accountLogin])
}

model GithubRepositoryConnection {
  id                 String    @id @default(cuid())
  githubRepositoryId BigInt
  installationId     String
  fullName           String
  ownerLogin         String
  repoName           String
  defaultBranch      String?
  isPrivate          Boolean
  enabled            Boolean   @default(true)
  branchFilters      String[]  @default(["main"])
  rootDirectory      String    @default("/")
  buildConfigJson    Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  installation GithubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([githubRepositoryId, installationId])
  @@index([installationId])
  @@index([fullName])
}

model GithubWebhookEvent {
  id                   String    @id @default(cuid())
  deliveryId           String    @unique
  eventName            String
  action               String?
  githubInstallationId BigInt?
  githubRepositoryId   BigInt?
  payloadJson          Json
  payloadSha256        String
  signatureValid       Boolean
  enqueueStatus        String    @default("queued")
  processStatus        String    @default("pending")
  processError         String?
  receivedAt           DateTime  @default(now())
  processedAt          DateTime?

  @@index([eventName])
  @@index([githubInstallationId])
  @@index([githubRepositoryId])
  @@index([processStatus])
}

enum SupportTicketDepartment {
  BILLING
  TECHNICAL
  ACCOUNT
  COMPLIANCE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketService {
  AUTH
  BILLING
  DEPLOY
  DOMAINS
  INTEGRATIONS
  DATA
  OTHER
}

enum SupportTicketAttachmentUploadTarget {
  CREATE
  REPLY
}

enum BillingAccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAUSED
  CANCELED
  ENDED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  CUSTOM
}

enum MeterAggregation {
  SUM
  MAX
  LAST
  COUNT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum InvoiceLineType {
  SUBSCRIPTION
  METERED
  ADJUSTMENT
  TAX
  CREDIT
}

enum InvoiceLineSourceType {
  RATED_USAGE
  ADJUSTMENT
  MANUAL
}

enum BillingAdjustmentType {
  CREDIT
  DEBIT
  WRITEOFF
}

enum BillingRunType {
  RATING
  INVOICING
  FINALIZATION
  RECONCILIATION
}

enum BillingRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum BillingAuditAction {
  CREATED
  UPDATED
  DELETED
  RUN_STARTED
  RUN_FINISHED
  INVOICE_GENERATED
}

enum BillingActorType {
  SYSTEM
  USER
  WORKER
}

// ─── Billing Enums ────────────────────────────────────────────────────────────
enum ServiceType {
  APP_HOSTING
  VPN
  WHATSAPP
}

enum SubscriptionType {
  PAYG
  BUNDLE
  CUSTOM
}

enum BillingMode {
  PACKAGE
  PAYG
  CUSTOM
}

enum BillingSubscriptionStatus2 {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum AdjustmentType {
  CREDIT
  DEBIT
}

model SupportTicket {
  id                        String                  @id @default(cuid())
  ticketNumber              String                  @unique
  organizationId            String
  requesterWorkosUserId     String
  assignedAgentWorkosUserId String?
  department                SupportTicketDepartment
  priority                  SupportTicketPriority
  service                   SupportTicketService?
  status                    SupportTicketStatus     @default(OPEN)
  subject                   String
  description               String?
  secureForm                String?
  attachmentsJson           Json?
  resolvedAt                DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  replies                SupportTicketReply[]
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketConsumedSessions")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@index([requesterWorkosUserId])
  @@index([assignedAgentWorkosUserId])
  @@index([department])
}

model SupportTicketReply {
  id                 String   @id @default(cuid())
  ticketId           String
  authorWorkosUserId String
  body               String
  secureForm         String?
  isInternalNote     Boolean  @default(false)
  attachmentsJson    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ticket                 SupportTicket                          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketReplyConsumedSessions")

  @@index([ticketId, createdAt])
  @@index([authorWorkosUserId])
  @@index([isInternalNote])
}

model SupportTicketAttachmentUploadSession {
  id                   String                              @id
  organizationId       String
  uploaderWorkosUserId String
  target               SupportTicketAttachmentUploadTarget
  ticketId             String?
  fileName             String
  mimeType             String
  sizeBytes            Int
  checksumSha256       String?
  storageKey           String
  storageBucket        String
  expiresAt            DateTime
  registeredAt         DateTime?
  consumedAt           DateTime?
  consumedTicketId     String?
  consumedReplyId      String?
  createdAt            DateTime                            @default(now())
  updatedAt            DateTime                            @updatedAt
  consumedTicket       SupportTicket?                      @relation("SupportTicketConsumedSessions", fields: [consumedTicketId], references: [id], onDelete: SetNull)
  consumedReply        SupportTicketReply?                 @relation("SupportTicketReplyConsumedSessions", fields: [consumedReplyId], references: [id], onDelete: SetNull)

  @@index([organizationId, uploaderWorkosUserId])
  @@index([target, ticketId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model BillingAccount {
  id             String               @id @default(cuid())
  tenantId       String               @unique
  organizationId String               @unique
  currency       String               @default("USD")
  timezone       String               @default("UTC")
  status         BillingAccountStatus @default(ACTIVE)
  balance        Decimal              @default(0) @db.Decimal(12, 2)
  metadataJson   Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant        Tenant?               @relation(fields: [tenantId], references: [id])
  subscriptions BillingSubscription[]
  usageEvents   UsageEvent[]
  ratedUsage    RatedUsage[]
  invoices      Invoice[]
  adjustments   BillingAdjustment[]
  runs          BillingRun[]
  auditLogs     BillingAuditLog[]
}

model BillingSubscription {
  id               String                    @id @default(cuid())
  billingAccountId String
  externalKey      String?
  status           BillingSubscriptionStatus @default(TRIALING)
  startedAt        DateTime
  canceledAt       DateTime?
  endedAt          DateTime?
  metadataJson     Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  billingAccount BillingAccount        @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  versions       SubscriptionVersion[]
  usageEvents    UsageEvent[]
  invoices       Invoice[]

  @@unique([billingAccountId, externalKey])
  @@index([billingAccountId, status])
}

model SubscriptionVersion {
  id             String    @id @default(cuid())
  subscriptionId String
  planVersionId  String
  version        Int
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  quantity       Decimal   @default(1) @db.Decimal(18, 6)
  metadataJson   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  planVersion  PlanVersion         @relation(fields: [planVersionId], references: [id], onDelete: Restrict)
  ratedUsage   RatedUsage[]

  @@unique([subscriptionId, version])
  @@index([subscriptionId, effectiveFrom(sort: Desc)])
  @@index([planVersionId])
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  isActive     Boolean  @default(true)
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions PlanVersion[]
}

model PlanVersion {
  id            String        @id @default(cuid())
  planId        String
  version       Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  billingPeriod BillingPeriod
  metadataJson  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  plan                 Plan                  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptionVersions SubscriptionVersion[]
  meterPrices          MeterPrice[]

  @@unique([planId, version])
  @@index([planId, effectiveFrom(sort: Desc)])
}

model Meter {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  eventName    String
  valueKey     String?
  aggregation  MeterAggregation
  isActive     Boolean          @default(true)
  metadataJson Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  meterPrices MeterPrice[]
  usageEvents UsageEvent[]

  @@index([eventName])
}

model MeterPrice {
  id            String    @id @default(cuid())
  meterId       String
  planVersionId String
  currency      String    @default("USD")
  unitPrice     Decimal   @db.Decimal(18, 6)
  includedUnits Decimal   @default(0) @db.Decimal(18, 6)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  metadataJson  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  meter       Meter        @relation(fields: [meterId], references: [id], onDelete: Cascade)
  planVersion PlanVersion  @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  ratedUsage  RatedUsage[]

  @@unique([meterId, planVersionId, effectiveFrom])
  @@index([meterId, planVersionId])
}

model UsageEvent {
  id               String   @id @default(cuid())
  billingAccountId String
  subscriptionId   String?
  meterId          String
  eventTimestamp   DateTime
  quantity         Decimal  @db.Decimal(18, 6)
  idempotencyKey   String
  source           String?
  externalEventId  String?
  payloadJson      Json?
  createdAt        DateTime @default(now())

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription   BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  meter          Meter                @relation(fields: [meterId], references: [id], onDelete: Restrict)
  ratedUsage     RatedUsage?

  @@unique([billingAccountId, idempotencyKey])
  @@index([billingAccountId, eventTimestamp])
  @@index([subscriptionId, meterId, eventTimestamp])
  @@index([meterId, eventTimestamp])
}

model RatedUsage {
  id                    String   @id @default(cuid())
  usageEventId          String   @unique
  billingAccountId      String
  subscriptionVersionId String?
  meterPriceId          String?
  invoiceLineId         String?
  quantity              Decimal  @db.Decimal(18, 6)
  unitPrice             Decimal  @db.Decimal(18, 6)
  amount                Decimal  @db.Decimal(18, 6)
  currency              String
  ratedAt               DateTime @default(now())
  createdAt             DateTime @default(now())

  usageEvent          UsageEvent           @relation(fields: [usageEventId], references: [id], onDelete: Cascade)
  billingAccount      BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscriptionVersion SubscriptionVersion? @relation(fields: [subscriptionVersionId], references: [id], onDelete: SetNull)
  meterPrice          MeterPrice?          @relation(fields: [meterPriceId], references: [id], onDelete: SetNull)
  invoiceLine         InvoiceLine?         @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, ratedAt])
  @@index([invoiceLineId])
  @@index([subscriptionVersionId])
}

model Invoice {
  id               String        @id @default(cuid())
  billingAccountId String
  tenantId         String?
  subscriptionId   String?
  billingRunId     String?
  invoiceNumber    String        @unique
  periodStart      DateTime
  periodEnd        DateTime
  currency         String
  status           InvoiceStatus @default(DRAFT)
  subtotalAmount   Decimal       @default(0) @db.Decimal(18, 6)
  taxAmount        Decimal       @default(0) @db.Decimal(18, 6)
  discountAmount   Decimal       @default(0) @db.Decimal(18, 6)
  totalAmount      Decimal       @default(0) @db.Decimal(18, 6)
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  metadataJson     Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  billingAccount BillingAccount?      @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  tenant         Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  subscription   BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingRun     BillingRun?          @relation(fields: [billingRunId], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  adjustments    BillingAdjustment[]

  @@unique([billingAccountId, periodStart, periodEnd])
  @@index([billingAccountId, status])
  @@index([subscriptionId, periodStart])
  @@index([billingRunId])
  @@index([tenantId, status])
  @@index([tenantId, periodStart])
}

model InvoiceLine {
  id           String          @id @default(cuid())
  invoiceId    String
  lineType     InvoiceLineType
  description  String
  quantity     Decimal         @db.Decimal(18, 6)
  unitPrice    Decimal         @db.Decimal(18, 6)
  amount       Decimal         @db.Decimal(18, 6)
  currency     String
  periodStart  DateTime?
  periodEnd    DateTime?
  metadataJson Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  invoice    Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sources    InvoiceLineSource[]
  ratedUsage RatedUsage[]

  @@index([invoiceId])
  @@index([lineType])
}

model InvoiceLineSource {
  id            String                @id @default(cuid())
  invoiceLineId String
  sourceType    InvoiceLineSourceType
  sourceId      String
  amount        Decimal               @db.Decimal(18, 6)
  metadataJson  Json?
  createdAt     DateTime              @default(now())

  invoiceLine InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)

  @@unique([invoiceLineId, sourceType, sourceId])
  @@index([sourceType, sourceId])
}

model BillingAdjustment {
  id                    String                @id @default(cuid())
  billingAccountId      String
  invoiceId             String?
  adjustmentType        BillingAdjustmentType
  amount                Decimal               @db.Decimal(18, 6)
  currency              String
  reason                String?
  createdByWorkosUserId String?
  appliedAt             DateTime?
  metadataJson          Json?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, createdAt(sort: Desc)])
  @@index([invoiceId])
}

model BillingRun {
  id               String           @id @default(cuid())
  billingAccountId String?
  runType          BillingRunType
  periodStart      DateTime
  periodEnd        DateTime
  status           BillingRunStatus @default(PENDING)
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  errorMessage     String?
  metadataJson     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  billingAccount BillingAccount?   @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
  auditLogs      BillingAuditLog[]

  @@unique([billingAccountId, runType, periodStart, periodEnd])
  @@index([billingAccountId, runType, startedAt(sort: Desc)])
}

model BillingAuditLog {
  id               String             @id @default(cuid())
  billingAccountId String?
  billingRunId     String?
  entityType       String
  entityId         String
  action           BillingAuditAction
  actorType        BillingActorType
  actorId          String?
  contextJson      Json?
  createdAt        DateTime           @default(now())

  billingAccount BillingAccount? @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)
  billingRun     BillingRun?     @relation(fields: [billingRunId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, createdAt(sort: Desc)])
  @@index([billingRunId, createdAt])
  @@index([entityType, entityId])
}

// ─── Billing Models ──────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions   Subscription[]
  usageLedgers    UsageLedger[]
  invoices        Invoice[]
  billingAccounts BillingAccount[]
}

model Region {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  country   String
  flag      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricings  Pricing[]

  @@index([isActive])
}

model Package {
  id          String       @id @default(cuid())
  code        ServiceType @unique
  name        String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  plans          ServicePlan[]
  subscriptions Subscription[]

  @@index([code])
}

model ServicePlan {
  id        String   @id @default(cuid())
  packageId String
  code      String
  name      String
  resources Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  package       Package        @relation(fields: [packageId], references: [id])
  pricings      Pricing[]
  subscriptions Subscription[]

  @@unique([packageId, code])
  @@index([packageId])
}

model Pricing {
  id              String           @id @default(cuid())
  planId          String
  regionId        String
  type            SubscriptionType
  billingMode     BillingMode
  basePriceIdr    Decimal          @db.Decimal(12, 2)
  monthlyCapIdr   Decimal?        @db.Decimal(12, 2)
  unitRateCpu     Decimal?        @db.Decimal(12, 4)
  unitRateMem     Decimal?        @db.Decimal(12, 4)
  unitRateMessage Decimal?        @db.Decimal(12, 4)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  servicePlan ServicePlan  @relation(fields: [planId], references: [id])
  region        Region          @relation(fields: [regionId], references: [id])
  subscriptions Subscription[]

  @@unique([planId, regionId, type, billingMode])
  @@index([planId])
  @@index([regionId])
}

model Subscription {
  id                  String                   @id @default(cuid())
  tenantId            String
  packageId           String
  planId              String
  pricingId           String
  type                SubscriptionType
  billingMode         BillingMode
  status              BillingSubscriptionStatus2 @default(ACTIVE)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  allocatedConfig     Json?
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  package      Package      @relation(fields: [packageId], references: [id])
  plan         ServicePlan  @relation(fields: [planId], references: [id])
  pricing      Pricing      @relation(fields: [pricingId], references: [id])
  usageLedgers UsageLedger[]

  @@unique([tenantId, packageId, planId])
  @@index([tenantId, status])
  @@index([packageId])
}

model UsageLedger {
  id             String   @id @default(cuid())
  tenantId       String
  subscriptionId String
  period         String
  metadata       Json?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  tenant       Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId, period])
  @@index([subscriptionId])
}

// ─── WhatsApp Enums ────────────────────────────────────────────────────────────

enum WhatsappDeviceStatus {
  ACTIVE
  NON_ACTIVE
}

enum WhatsappContactGroupStatus {
  ACTIVE
  INACTIVE
}

enum WhatsappContactGroupType {
  STATIC
  DYNAMIC
}

enum WhatsappContactStatus {
  ACTIVE
  INACTIVE
}

enum WhatsappTemplateSyncStatus {
  SYNCED
  NOT_SYNCED
  NOT_IN_META
}

enum WhatsappTemplateMetaStatus {
  APPROVED
  PENDING
  REJECTED
}

enum WhatsappBroadcastStatus {
  QUEUED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
}

enum WhatsappBroadcastRecipientStatus {
  QUEUED
  SENT
  FAILED
}

enum WhatsappMessageDirection {
  INBOX
  OUTBOX
}

enum WhatsappMessageDeliveryStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum WhatsappBillingCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
  SERVICE
}

enum WhatsappBillingStatus {
  CHARGED_PENDING_VERIFY
  CONFIRMED
  REVERTED_FAILED
}

enum WhatsappLogType {
  INFO
  ERROR
  INBOX
  AUDIT
}

enum WhatsappApiKeyEnvironment {
  SANDBOX
  LIVE
}

// ─── WhatsApp Models ──────────────────────────────────────────────────────────

model WhatsappDevice {
  id                        String               @id @default(cuid())
  organizationId            String
  phoneNumber               String               @unique
  balance                   Decimal              @default(0) @db.Decimal(12, 2)
  quotaBase                 Decimal              @default(1000) @db.Decimal(12, 2)
  quotaBaseIn               Int                  @default(0)
  quotaBaseOut              Int                  @default(0)
  dailyLimitMessage         Int                  @default(0)
  rates                     String?
  status                    WhatsappDeviceStatus @default(ACTIVE)
  token                     String?
  tokenEncrypted            String?
  tokenIv                   String?
  s3Path                    String?
  whatsappBusinessAccountId String?
  whatsappPhoneId           String?
  whatsappApplicationId     String?
  whatsappVersion           String               @default("v24.0")
  whatsappProfile           Json?
  features                  Json?
  callbackUrl               String?
  callbackHeaderName        String?
  callbackHeaderValue       String?
  expiredAt                 DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  contacts             WhatsappContact[]
  contactGroups        WhatsappContactGroup[]
  templates            WhatsappTemplate[]
  broadcastCampaigns   WhatsappBroadcastCampaign[]
  messageConversations WhatsappConversation[]
  dailyCounts          WhatsappDailyCount[]
  monthlyCounts        WhatsappMonthlyCount[]
  quotaSessions        WhatsappQuotaSession[]
  billingLedgers       WhatsappBillingLedger[]
  logs                 WhatsappLog[]
  attachments          WhatsappAttachment[]
  broadcastRateStates  WhatsappBroadcastRateState[]
  webhooks             WhatsappWebhook[]

  @@index([organizationId])
  @@index([whatsappBusinessAccountId])
}

model WhatsappContactGroup {
  id                  String                     @id @default(cuid())
  organizationId      String
  name                String                     @db.VarChar(100)
  description         String                     @db.VarChar(500)
  type                WhatsappContactGroupType   @default(STATIC)
  status              WhatsappContactGroupStatus @default(ACTIVE)
  throttleMaxMessages Int?
  throttlePerMinutes  Int?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  contacts                     WhatsappContact[]
  whatsappBroadcasts           WhatsappBroadcastCampaign[]
  broadcastRateState           WhatsappBroadcastRateState?
  whatsappDevice               WhatsappDevice?             @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId             String?
  whatsappBroadcastRateStateId String?

  @@index([organizationId, status])
}

model WhatsappContact {
  id              String                @id @default(cuid())
  organizationId  String
  phoneNumber     String                @db.VarChar(20)
  name            String                @db.VarChar(100)
  email           String                @db.VarChar(255)
  status          WhatsappContactStatus @default(ACTIVE)
  lastContactedAt DateTime?
  waId            String?
  isWhatsapp      Boolean               @default(false)
  lastCheckedAt   DateTime?
  dynamicValues   Json?
  dynamicRaw      String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  contactGroup     WhatsappContactGroup @relation(fields: [contactGroupId], references: [id], onDelete: Restrict)
  contactGroupId   String
  whatsappDevice   WhatsappDevice?      @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@unique([organizationId, phoneNumber])
  @@index([organizationId, contactGroupId, status])
  @@index([organizationId, createdAt])
}

model WhatsappTemplate {
  id             String                      @id @default(cuid())
  organizationId String
  slug           String
  name           String
  description    String?
  syncStatus     WhatsappTemplateSyncStatus  @default(NOT_SYNCED)
  metaStatus     WhatsappTemplateMetaStatus?
  lastSyncedAt   DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  languages        WhatsappTemplateLanguage[]
  whatsappDevice   WhatsappDevice?            @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@index([organizationId, metaStatus])
}

model WhatsappTemplateLanguage {
  id           String                      @id @default(cuid())
  templateId   String
  template     WhatsappTemplate            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  lang         String
  headerType   String?
  headerUrl    String?
  headerText   String?
  body         String?
  parameters   Json?
  footer       String?
  buttons      Json?
  authConfig   Json?
  isApproved   Boolean                     @default(false)
  metaStatus   WhatsappTemplateMetaStatus?
  rejectReason String?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@unique([templateId, lang])
}

model WhatsappBroadcastCampaign {
  id                  String                  @id @default(cuid())
  organizationId      String
  templateName        String
  templateLanguage    String
  templateParams      Json?
  throttleMaxMessages Int?
  throttlePerMinutes  Int?
  status              WhatsappBroadcastStatus @default(QUEUED)
  total               Int                     @default(0)
  queued              Int                     @default(0)
  sent                Int                     @default(0)
  failed              Int                     @default(0)
  startedAt           DateTime?
  endedAt             DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  recipients             WhatsappBroadcastRecipient[]
  whatsappDevice         WhatsappDevice?              @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId       String?
  whatsappContactGroup   WhatsappContactGroup?        @relation(fields: [whatsappContactGroupId], references: [id])
  whatsappContactGroupId String?

  @@index([organizationId, status])
}

model WhatsappBroadcastRecipient {
  id            String                           @id @default(cuid())
  broadcastId   String
  broadcast     WhatsappBroadcastCampaign        @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  phoneNumber   String
  name          String?
  dynamicValues Json?
  status        WhatsappBroadcastRecipientStatus @default(QUEUED)
  attempts      Int                              @default(0)
  waMessageId   String?
  lastError     String?
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt

  @@index([broadcastId, status])
}

model WhatsappConversation {
  id             String                    @id @default(cuid())
  organizationId String
  contactPhone   String
  lastMessageAt  DateTime?
  lastDirection  WhatsappMessageDirection?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  whatsappMessages WhatsappMessage[]
  whatsappDevice   WhatsappDevice?   @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@unique([organizationId, contactPhone])
  @@index([organizationId, lastMessageAt])
}

model WhatsappMessage {
  id             String                   @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      WhatsappMessageDirection
  messageType    String
  body           String?
  mediaUrl       String?
  waMessageId    String?                  @unique
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  statusHistory WhatsappMessageStatus[]

  @@index([conversationId, createdAt])
}

model WhatsappMessageStatus {
  id              String                        @id @default(cuid())
  messageId       String
  message         WhatsappMessage               @relation(fields: [messageId], references: [id], onDelete: Cascade)
  status          WhatsappMessageDeliveryStatus
  timestamp       DateTime?
  error           String?
  createdAt       DateTime                      @default(now())

  @@index([messageId, createdAt])
}

model WhatsappDailyCount {
  id                 String          @id @default(cuid())
  organizationId     String
  date               DateTime        @db.Date
  sessionCount       Int             @default(0)
  messageInboxCount  Int             @default(0)
  messageOutboxCount Int             @default(0)
  messageFailedCount Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  whatsappDevice     WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId   String?

  @@unique([organizationId, date, whatsappDeviceId])
}

model WhatsappMonthlyCount {
  id                 String          @id @default(cuid())
  organizationId     String
  year               Int
  month              Int
  sessionCount       Int             @default(0)
  messageInboxCount  Int             @default(0)
  messageOutboxCount Int             @default(0)
  messageFailedCount Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  whatsappDevice     WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId   String?

  @@unique([organizationId, year, month, whatsappDeviceId])
}

model WhatsappQuotaSession {
  id               String          @id @default(cuid())
  organizationId   String
  phoneNumber      String
  category         String
  expiredAt        DateTime
  createdAt        DateTime        @default(now())
  whatsappDevice   WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@unique([organizationId, phoneNumber, category])
}

model WhatsappBillingLedger {
  id              String                @id @default(cuid())
  organizationId  String
  waMessageId     String
  phoneNumber     String
  category        WhatsappBillingCategory
  quotaKey        String
  quotaValue      Decimal               @db.Decimal(12, 2)
  status          WhatsappBillingStatus @default(CHARGED_PENDING_VERIFY)
  isReverted      Boolean               @default(false)
  revertReason    String?
  revertedAt      DateTime?
  lastStatus      String?
  pricingBillable Boolean?
  pricingCategory String?
  errorCode       String?
  errorTitle      String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  whatsappDevice  WhatsappDevice?       @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@index([organizationId, createdAt])
  @@index([waMessageId])
}

model WhatsappLog {
  id               String          @id @default(cuid())
  organizationId   String
  type             WhatsappLogType
  message          String
  metadata         Json?
  createdAt        DateTime        @default(now())
  whatsappDevice   WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@index([organizationId, type, createdAt])
}

model WhatsappAttachment {
  id               String          @id @default(cuid())
  organizationId   String
  fileName         String
  mimeType         String
  size             Int
  s3Path           String
  publicUrl        String?
  createdAt        DateTime        @default(now())
  whatsappDevice   WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId String?

  @@index([organizationId, createdAt])
}

model WhatsappBroadcastRateState {
  id                  String                 @id @default(cuid())
  organizationId      String
  whatsappContactGroupId String                 @unique
  whatsappContactGroup WhatsappContactGroup    @relation(fields: [whatsappContactGroupId], references: [id], onDelete: Cascade)
  lastMessageSentAt   DateTime?
  messagesSentInWindow Int                    @default(0)
  windowStartAt       DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  whatsappDevice      WhatsappDevice?        @relation(fields: [whatsappDeviceId], references: [id])
  whatsappDeviceId    String?

  @@index([organizationId])
}

model WhatsappApiKey {
  id               String                   @id @default(cuid())
  organizationId   String
  name             String
  key              String                   @unique
  environment      WhatsappApiKeyEnvironment @default(SANDBOX)
  isActive         Boolean                  @default(true)
  lastUsedAt       DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([organizationId, key])
}

model WhatsappWebhook {
  id                 String          @id @default(cuid())
  organizationId     String
  whatsappDeviceId   String
  webhookUrl         String
  verifyToken        String
  active             Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  whatsappDevice     WhatsappDevice? @relation(fields: [whatsappDeviceId], references: [id])

  @@index([organizationId])
  @@index([whatsappDeviceId])
}
