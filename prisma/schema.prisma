enum VpnProtocol {
  OPENVPN
  WIREGUARD
  PROXY
}

enum VpnSubscriptionStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum VpnProvisioningStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
  REVOKED
}

model VpnSubscription {
  id                 String                @id @default(cuid())
  organizationId     String
  packageId          String
  status             VpnSubscriptionStatus @default(ACTIVE)
  // Price locked at purchase time. Package price changes never affect an
  // existing subscription (grandfathering, Story 16).
  priceLocked        Decimal               @db.Decimal(12, 2)
  currency           String                @default("IDR")
  // Original package price at purchase time (before any currency conversion).
  // Null for subscriptions created before multi-currency support.
  originalPrice    Decimal?              @db.Decimal(12, 2)
  originalCurrency String?
  // Exchange rate used at purchase time (units of originalCurrency per 1 base unit).
  exchangeRate     Decimal?              @db.Decimal(18, 6)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  // First timestamp a renewal failed for insufficient balance. Drives the
  // grace ladder (3-day suspend, 7-day expire). Cleared on successful renewal.
  renewalFailedAt    DateTime?
  cancelAtPeriodEnd  Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  serverAccounts VpnServerAccount[]
  mobileDevices  VpnMobileDevice[]
  pairingTokens  VpnPairingToken[]

  @@index([organizationId, status])
  @@index([packageId])
  @@index([currentPeriodEnd])
}

model VpnServerAccount {
  id                 String                @id @default(cuid())
  subscriptionId     String
  serverId           String
  protocol           VpnProtocol
  username           String
  password           String?
  configEncrypted    String?
  provisioningStatus VpnProvisioningStatus @default(PENDING)
  failureReason      String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  subscription VpnSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  server       VpnServer       @relation(fields: [serverId], references: [id])

  @@unique([serverId, protocol, username])
  @@index([subscriptionId])
  @@index([serverId])
  @@index([provisioningStatus])
}

