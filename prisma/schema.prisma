generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthApiKeyEnvironment {
  SANDBOX
  LIVE

  @@map("ApiKeyEnvironment")
}

enum AuthPlatformRole {
  NONE
  SUPER_ADMIN

  @@map("PlatformRole")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthPlatformUserRole {
  id           String           @id @default(cuid())
  workosUserId String           @unique
  email        String?          @unique
  role         AuthPlatformRole @default(NONE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("PlatformUserRole")
}

model AuthApiKey {
  id             String                @id @default(cuid())
  name           String
  organizationId String
  keyHash        String
  environment    AuthApiKeyEnvironment @default(SANDBOX)
  scopes         String[]
  active         Boolean               @default(true)
  expiresAt      DateTime?
  createdBy      String?
  lastUsedAt     DateTime?
  lastUsedIp     String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@map("ApiKey")
}

model DocsKnowledgeDocument {
  id                    String   @id @default(cuid())
  organizationId        String?
  path                  String
  title                 String
  purpose               String
  howTo                 String[]
  notes                 String[]
  searchText            String
  embedding             Float[]  @default([])
  updatedByWorkosUserId String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, path])
  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@map("KnowledgeDocument")
}

model GithubInstallStateNonce {
  id             String    @id @default(cuid())
  nonceHash      String    @unique
  workosUserId   String
  organizationId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([expiresAt])
  @@index([workosUserId])
  @@index([organizationId])
}

model GithubInstallation {
  id                   String   @id @default(cuid())
  githubInstallationId BigInt   @unique
  accountLogin         String
  accountType          String
  targetType           String
  targetId             BigInt?
  workosUserId         String
  organizationId       String?
  status               String   @default("active")
  permissionsJson      Json?
  eventsSubscribed     Json?
  installedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  repositories GithubRepositoryConnection[]

  @@index([workosUserId])
  @@index([organizationId])
  @@index([accountLogin])
}

model GithubRepositoryConnection {
  id                 String    @id @default(cuid())
  githubRepositoryId BigInt
  installationId     String
  fullName           String
  ownerLogin         String
  repoName           String
  defaultBranch      String?
  isPrivate          Boolean
  enabled            Boolean   @default(true)
  branchFilters      String[]  @default(["main"])
  rootDirectory      String    @default("/")
  buildConfigJson    Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  installation GithubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  stacks ApplicationStack[]

  @@unique([githubRepositoryId, installationId])
  @@index([installationId])
  @@index([fullName])
}

enum StackStatus {
  IDLE
  QUEUED
  BUILDING
  DEPLOYING
  RUNNING
  FAILED
}

enum DeploySource {
  GITHUB
  TEMPLATE
  MANUAL
}

// DetectorRule is used by the AI framework detection engine to store
// governance rules that influence classification and build recommendations.
model DetectorRule {
  id               String   @id @default(cuid())
  name             String
  description      String?
  patternJson      Json // Match criteria: files, dependencies, etc.
  implicationsJson Json // Results: framework, runtime, build hints
  confidenceWeight Float    @default(1.0)
  isActive         Boolean  @default(true)
  priority         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
}

model DetectorRuntimeMapping {
  id               String   @id(map: "DRM_pkey") @default(cuid())
  frameworkId      String // e.g., "laravel", "nextjs"
  frameworkVersion String? // e.g., "10", "14" (null = wildcard for all versions)
  runtimeId        String // e.g., "php", "node"
  runtimeVersion   String // e.g., "8.2", "20"
  buildVersion     String? // e.g., "node-20" for asset build step
  isActive         Boolean  @default(true)
  priority         Int      @default(0) // Higher priority wins on conflict
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([frameworkId, frameworkVersion, runtimeId], map: "DRM_frameworkId_frameworkVersion_runtimeId_key")
  @@index([frameworkId, isActive], map: "DRM_frameworkId_isActive_idx")
  @@map("RuntimeMapping")
}

model DetectorInspectionLog {
  id                String   @id(map: "DetectorInspectionLog_pkey") @default(cuid())
  installationId    BigInt? // GitHub installation ID (null if git-clone mode)
  repoUrl           String
  ref               String?
  detectedFramework String?
  confidence        Float?
  enforcedRuntimes  Json? // Array of {runtimeId, version} after policy enforcement
  toolCalls         Json? // Array of {tool, input, output} for AI tool calls
  reasoning         String[] // AI reasoning steps
  warnings          String[]
  durationMs        Int?
  status            String   @default("success") // success, blocked, error, unsupported
  blockedByRuleId   String? // DetectorRule ID if blocked
  errorMessage      String?
  createdAt         DateTime @default(now())

  @@index([repoUrl], map: "DetectorInspectionLog_repoUrl_idx")
  @@index([detectedFramework], map: "DetectorInspectionLog_detectedFramework_idx")
  @@index([status], map: "DetectorInspectionLog_status_idx")
  @@index([createdAt], map: "DetectorInspectionLog_createdAt_idx")
  @@map("InspectionLog")
}

model ApplicationStack {
  id                     String       @id @default(cuid())
  organizationId         String
  name                   String
  slug                   String
  status                 StackStatus  @default(IDLE)
  sourceType             DeploySource @default(GITHUB)
  repositoryConnectionId String?
  branchName             String       @default("main")
  rootDirectory          String       @default("/")
  framework              String?
  buildCommand           String?
  dockerfileDetected     Boolean      @default(false)
  resourcePlanId         String?
  billingMode            String?      @default("PAYG")
  hourlyCost             Decimal?     @db.Decimal(10, 4)
  cpu                    Int?
  memory                 Int?
  customDomain           String?
  subdomain              String?
  envVarsJson            Json         @default("[]")
  metadataJson           Json?
  lastDeployedAt         DateTime?
  lastDeployStatus       StackStatus?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  deployments          ApplicationDeployment[]
  repositoryConnection GithubRepositoryConnection? @relation(fields: [repositoryConnectionId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([repositoryConnectionId])
  @@index([status])
}

model ApplicationDeployment {
  id               String       @id @default(cuid())
  stackId          String
  organizationId   String
  status           StackStatus  @default(QUEUED)
  triggerType      DeploySource @default(MANUAL)
  commitSha        String?
  commitMessage    String?
  commitAuthor     String?
  branchName       String       @default("main")
  manifestPushed   Boolean      @default(false)
  manifestPushedAt DateTime?
  argocdSynced     Boolean      @default(false)
  argocdSyncedAt   DateTime?
  startedAt        DateTime     @default(now())
  completedAt      DateTime?
  failureReason    String?
  rollbackOfId     String?
  attempt          Int          @default(1)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  stack  ApplicationStack           @relation(fields: [stackId], references: [id], onDelete: Cascade)
  events ApplicationDeployEvent[]
  logs   ApplicationDeploymentLog[]

  @@index([stackId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("Deployment")
}

enum ApplicationDeployEventType {
  QUEUED
  BUILD_STARTED
  MANIFEST_PUSHED
  ARGOCD_SYNC_STARTED
  ARGOCD_SYNCED
  DEPLOY_COMPLETED
  DEPLOY_FAILED
  ROLLBACK_STARTED
  ROLLBACK_COMPLETED
}

model ApplicationDeployEvent {
  id           String                     @id @default(cuid())
  deploymentId String
  type         ApplicationDeployEventType
  message      String?
  metadataJson Json?
  createdAt    DateTime                   @default(now())

  deployment ApplicationDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("DeployEvent")
}

model ApplicationDeploymentLog {
  id           String   @id @default(cuid())
  deploymentId String
  scope        String   @default("runtime")
  status       String
  message      String
  timestamp    DateTime @default(now())

  deployment ApplicationDeployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId])
  @@index([timestamp(sort: Desc)])
  @@map("DeploymentLog")
}

model GithubWebhookEvent {
  id                     String    @id @default(cuid())
  deliveryId             String    @unique
  eventName              String
  action                 String?
  githubInstallationId   BigInt?
  githubRepositoryId     BigInt?
  repositoryFullName     String?
  repositoryOwner        String?
  repositoryName         String?
  ref                    String?
  branch                 String?
  commitSha              String?
  commitMessage          String?
  commitAuthorName       String?
  commitAuthorEmail      String?
  commitUrl              String?
  senderLogin            String?
  senderAvatarUrl        String?
  repositoryConnectionId String?
  applicationStackId     String?
  eventDisposition       String    @default("tracked")
  ignoreReason           String?
  responseStatus         Int?
  handlerDurationMs      Int?
  payloadJson            Json
  payloadSha256          String
  signatureValid         Boolean
  enqueueStatus          String    @default("queued")
  processStatus          String    @default("pending")
  processError           String?
  receivedAt             DateTime  @default(now())
  processedAt            DateTime?
  deletedAt              DateTime?
  deleteReason           String?
  permanentDeleteAfter   DateTime?

  @@index([eventName])
  @@index([githubInstallationId])
  @@index([githubRepositoryId])
  @@index([githubInstallationId, githubRepositoryId])
  @@index([repositoryConnectionId])
  @@index([applicationStackId])
  @@index([repositoryFullName])
  @@index([branch])
  @@index([commitSha])
  @@index([senderLogin])
  @@index([eventDisposition])
  @@index([eventName, processStatus])
  @@index([processStatus])
  @@index([deletedAt])
  @@index([permanentDeleteAfter])
  @@index([receivedAt(sort: Desc)])
}

enum SupportTicketDepartment {
  BILLING
  TECHNICAL
  ACCOUNT
  COMPLIANCE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketService {
  AUTH
  BILLING
  DEPLOY
  DOMAINS
  INTEGRATIONS
  DATA
  OTHER
}

enum SupportTicketAttachmentUploadTarget {
  CREATE
  REPLY
}

enum BillingAccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAUSED
  CANCELED
  ENDED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  CUSTOM
}

enum MeterAggregation {
  SUM
  MAX
  LAST
  COUNT
}

enum BillingInvoiceStatus {
  DRAFT
  ISSUED
  OPEN
  PAID
  OVERDUE
  CANCELLED
  VOID
  UNCOLLECTIBLE
}

enum BillingInvoiceLineType {
  SUBSCRIPTION
  METERED
  ADJUSTMENT
  TAX
  CREDIT
}

enum BillingInvoiceLineSourceType {
  RATED_USAGE
  ADJUSTMENT
  MANUAL
}

enum BillingAdjustmentType {
  CREDIT
  DEBIT
  WRITEOFF
}

enum BillingRunType {
  RATING
  INVOICING
  FINALIZATION
  RECONCILIATION
}

enum BillingRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum BillingAuditAction {
  CREATED
  UPDATED
  DELETED
  RUN_STARTED
  RUN_FINISHED
  INVOICE_GENERATED
}

enum BillingActorType {
  SYSTEM
  USER
  WORKER
}

// ─── Billing Enums ────────────────────────────────────────────────────────────
enum ServiceType {
  APP_HOSTING
  VPN
  WHATSAPP
}

enum SubscriptionType {
  PAYG
  BUNDLE
  CUSTOM
}

enum BillingMode {
  PACKAGE
  PAYG
  CUSTOM
}

enum BillingSubscriptionStatus2 {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BillingCurrency {
  USD
  IDR
}

enum BillingContactRole {
  OWNER
  FINANCE
  ACCOUNTING
  GENERAL
}

enum VpnProvider {
  OPENVPN
}

enum VpnRegionCode {
  INDONESIA
}

enum VpnClientStatus {
  ACTIVE
  REVOKED
  EXPIRED
  PROVISIONING_FAILED
}

enum VpnServerHealth {
  HEALTHY
  WARNING
  DOWN
  UNKNOWN
}

enum AdjustmentType {
  CREDIT
  DEBIT
}

model SupportTicket {
  id                        String                  @id @default(cuid())
  ticketNumber              String                  @unique
  organizationId            String
  requesterWorkosUserId     String
  assignedAgentWorkosUserId String?
  department                SupportTicketDepartment
  priority                  SupportTicketPriority
  service                   SupportTicketService?
  status                    SupportTicketStatus     @default(OPEN)
  subject                   String
  description               String?
  secureForm                String?
  attachmentsJson           Json?
  resolvedAt                DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  replies                SupportTicketReply[]
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketConsumedSessions")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@index([requesterWorkosUserId])
  @@index([assignedAgentWorkosUserId])
  @@index([department])
}

model SupportTicketReply {
  id                 String   @id @default(cuid())
  ticketId           String
  authorWorkosUserId String
  body               String
  secureForm         String?
  isInternalNote     Boolean  @default(false)
  attachmentsJson    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ticket                 SupportTicket                          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketReplyConsumedSessions")

  @@index([ticketId, createdAt])
  @@index([authorWorkosUserId])
  @@index([isInternalNote])
}

model SupportTicketAttachmentUploadSession {
  id                   String                              @id
  organizationId       String
  uploaderWorkosUserId String
  target               SupportTicketAttachmentUploadTarget
  ticketId             String?
  fileName             String
  mimeType             String
  sizeBytes            Int
  checksumSha256       String?
  storageKey           String
  storageBucket        String
  expiresAt            DateTime
  registeredAt         DateTime?
  consumedAt           DateTime?
  consumedTicketId     String?
  consumedReplyId      String?
  createdAt            DateTime                            @default(now())
  updatedAt            DateTime                            @updatedAt
  consumedTicket       SupportTicket?                      @relation("SupportTicketConsumedSessions", fields: [consumedTicketId], references: [id], onDelete: SetNull)
  consumedReply        SupportTicketReply?                 @relation("SupportTicketReplyConsumedSessions", fields: [consumedReplyId], references: [id], onDelete: SetNull)

  @@index([organizationId, uploaderWorkosUserId])
  @@index([target, ticketId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model BillingAccount {
  id                String               @id @default(cuid())
  organizationId    String               @unique
  tenantId          String?
  currency          String               @default("IDR")
  preferredCurrency BillingCurrency      @default(USD)
  timezone          String               @default("UTC")
  status            BillingAccountStatus @default(ACTIVE)
  balance           Decimal              @default(0) @db.Decimal(12, 2)
  metadataJson      Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  subscriptions BillingSubscription[]
  usageEvents   BillingUsageEvent[]
  ratedUsage    BillingRatedUsage[]
  invoices      BillingInvoice[]
  adjustments   BillingAdjustment[]
  runs          BillingRun[]
  auditLogs     BillingAuditLog[]
  contacts      BillingContact[]
}

model BillingContact {
  id                 String             @id @default(cuid())
  billingAccountId   String
  billingAccount     BillingAccount     @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  email              String
  name               String?
  role               BillingContactRole @default(GENERAL)
  notifyOnInvoice    Boolean            @default(true)
  notifyOnLowBalance Boolean            @default(true)
  notifyOnSupport    Boolean            @default(true)
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([billingAccountId, email])
  @@index([billingAccountId])
}

model BillingSubscription {
  id               String                    @id @default(cuid())
  billingAccountId String
  externalKey      String?
  status           BillingSubscriptionStatus @default(TRIALING)
  startedAt        DateTime
  canceledAt       DateTime?
  endedAt          DateTime?
  metadataJson     Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  billingAccount BillingAccount               @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  versions       ServiceSubscriptionVersion[]
  usageEvents    BillingUsageEvent[]
  invoices       BillingInvoice[]

  @@unique([billingAccountId, externalKey])
  @@index([billingAccountId, status])
}

model ServiceSubscriptionVersion {
  id             String    @id(map: "ServiceSubscriptionVersion_pkey") @default(cuid())
  subscriptionId String
  planVersionId  String
  version        Int
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  quantity       Decimal   @default(1) @db.Decimal(18, 6)
  metadataJson   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  planVersion  BillingPlanTier     @relation(fields: [planVersionId], references: [id], onDelete: Restrict)
  ratedUsage   BillingRatedUsage[]

  @@unique([subscriptionId, version], map: "ServiceSubscriptionVersion_subscriptionId_version_key")
  @@index([subscriptionId, effectiveFrom(sort: Desc)], map: "ServiceSubscriptionVersion_subscriptionId_effectiveFrom_idx")
  @@index([planVersionId], map: "ServiceSubscriptionVersion_planVersionId_idx")
  @@map("SubscriptionVersion")
}

model BillingPlan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  isActive     Boolean  @default(true)
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions BillingPlanTier[]

  @@map("Plan")
}

model BillingPlanTier {
  id            String        @id @default(cuid())
  planId        String
  version       Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  billingPeriod BillingPeriod
  metadataJson  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  plan                 BillingPlan                  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptionVersions ServiceSubscriptionVersion[]
  meterPrices          BillingMeterPrice[]

  @@unique([planId, version])
  @@index([planId, effectiveFrom(sort: Desc)])
  @@map("PlanVersion")
}

model BillingMeter {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  eventName    String
  valueKey     String?
  aggregation  MeterAggregation
  isActive     Boolean          @default(true)
  metadataJson Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  meterPrices BillingMeterPrice[]
  usageEvents BillingUsageEvent[]

  @@index([eventName])
  @@map("Meter")
}

model BillingMeterPrice {
  id            String    @id @default(cuid())
  meterId       String
  planVersionId String
  currency      String    @default("USD")
  unitPrice     Decimal   @db.Decimal(18, 6)
  includedUnits Decimal   @default(0) @db.Decimal(18, 6)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  metadataJson  Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  meter       BillingMeter        @relation(fields: [meterId], references: [id], onDelete: Cascade)
  planVersion BillingPlanTier     @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  ratedUsage  BillingRatedUsage[]

  @@unique([meterId, planVersionId, effectiveFrom])
  @@index([meterId, planVersionId])
  @@map("MeterPrice")
}

model BillingUsageEvent {
  id               String   @id @default(cuid())
  billingAccountId String
  subscriptionId   String?
  meterId          String
  eventTimestamp   DateTime
  quantity         Decimal  @db.Decimal(18, 6)
  idempotencyKey   String
  source           String?
  externalEventId  String?
  payloadJson      Json?
  createdAt        DateTime @default(now())

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription   BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  meter          BillingMeter         @relation(fields: [meterId], references: [id], onDelete: Restrict)
  ratedUsage     BillingRatedUsage?

  @@unique([billingAccountId, idempotencyKey])
  @@index([billingAccountId, eventTimestamp])
  @@index([subscriptionId, meterId, eventTimestamp])
  @@index([meterId, eventTimestamp])
  @@map("UsageEvent")
}

model BillingRatedUsage {
  id                    String   @id @default(cuid())
  usageEventId          String   @unique
  billingAccountId      String
  subscriptionVersionId String?
  meterPriceId          String?
  invoiceLineId         String?
  quantity              Decimal  @db.Decimal(18, 6)
  unitPrice             Decimal  @db.Decimal(18, 6)
  amount                Decimal  @db.Decimal(18, 6)
  currency              String
  ratedAt               DateTime @default(now())
  createdAt             DateTime @default(now())

  usageEvent          BillingUsageEvent           @relation(fields: [usageEventId], references: [id], onDelete: Cascade)
  billingAccount      BillingAccount              @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscriptionVersion ServiceSubscriptionVersion? @relation(fields: [subscriptionVersionId], references: [id], onDelete: SetNull)
  meterPrice          BillingMeterPrice?          @relation(fields: [meterPriceId], references: [id], onDelete: SetNull)
  invoiceLine         BillingInvoiceLine?         @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, ratedAt])
  @@index([invoiceLineId])
  @@index([subscriptionVersionId])
  @@map("RatedUsage")
}

model BillingInvoice {
  id               String               @id @default(cuid())
  billingAccountId String
  subscriptionId   String?
  billingRunId     String?
  invoiceNumber    String               @unique
  periodStart      DateTime
  periodEnd        DateTime
  currency         String
  status           BillingInvoiceStatus @default(DRAFT)
  subtotalAmount   Decimal              @default(0) @db.Decimal(18, 6)
  taxAmount        Decimal              @default(0) @db.Decimal(18, 6)
  discountAmount   Decimal              @default(0) @db.Decimal(18, 6)
  totalAmount      Decimal              @default(0) @db.Decimal(18, 6)
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  // Payment module fields
  type             String? // "TOP_UP", "SERVICE", "RECURRING"
  paymentMethod    String? // "VA", "QRIS", "MANUAL_BANK"
  gatewayId        String?
  dueDate          DateTime?
  metadata         Json? // { duitkuReference, vaNumber, paymentUrl }
  metadataJson     Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  billingAccount       BillingAccount?       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription         BillingSubscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingRun           BillingRun?           @relation(fields: [billingRunId], references: [id], onDelete: SetNull)
  gateway              PaymentGateway?       @relation(fields: [gatewayId], references: [id])
  lines                BillingInvoiceLine[]
  adjustments          BillingAdjustment[]
  paymentConfirmations PaymentConfirmation[]

  @@unique([billingAccountId, periodStart, periodEnd])
  @@index([billingAccountId, status])
  @@index([subscriptionId, periodStart])
  @@index([billingRunId])
  @@map("Invoice")
}

model BillingInvoiceLine {
  id           String                 @id @default(cuid())
  invoiceId    String
  lineType     BillingInvoiceLineType
  description  String
  quantity     Decimal                @db.Decimal(18, 6)
  unitPrice    Decimal                @db.Decimal(18, 6)
  amount       Decimal                @db.Decimal(18, 6)
  currency     String
  periodStart  DateTime?
