generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  NONE
  SUPER_ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformUserRole {
  id           String       @id @default(cuid())
  workosUserId String       @unique
  email        String?      @unique
  role         PlatformRole @default(NONE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model KnowledgeDocument {
  id                    String   @id @default(cuid())
  organizationId        String?
  path                  String
  title                 String
  purpose               String
  howTo                 String[]
  notes                 String[]
  searchText            String
  embedding             Float[]
  updatedByWorkosUserId String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, path])
  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model GithubInstallStateNonce {
  id             String   @id @default(cuid())
  nonceHash      String   @unique
  workosUserId   String
  organizationId String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime @default(now())

  @@index([expiresAt])
  @@index([workosUserId])
  @@index([organizationId])
}

model GithubInstallation {
  id                   String   @id @default(cuid())
  githubInstallationId BigInt   @unique
  accountLogin         String
  accountType          String
  targetType           String
  targetId             BigInt?
  workosUserId         String
  organizationId       String?
  status               String   @default("active")
  permissionsJson      Json?
  eventsSubscribed     Json?
  installedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  repositories GithubRepositoryConnection[]

  @@index([workosUserId])
  @@index([organizationId])
  @@index([accountLogin])
}

model GithubRepositoryConnection {
  id                 String   @id @default(cuid())
  githubRepositoryId BigInt
  installationId     String
  fullName           String
  ownerLogin         String
  repoName           String
  defaultBranch      String?
  isPrivate          Boolean
  enabled            Boolean  @default(true)
  branchFilters      String[] @default(["main"])
  rootDirectory      String   @default("/")
  buildConfigJson    Json?
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  installation GithubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([githubRepositoryId, installationId])
  @@index([installationId])
  @@index([fullName])
}

model GithubWebhookEvent {
  id                   String   @id @default(cuid())
  deliveryId           String   @unique
  eventName            String
  action               String?
  githubInstallationId BigInt?
  githubRepositoryId   BigInt?
  payloadJson          Json
  payloadSha256        String
  signatureValid       Boolean
  enqueueStatus        String   @default("queued")
  processStatus        String   @default("pending")
  processError         String?
  receivedAt           DateTime @default(now())
  processedAt          DateTime?

  @@index([eventName])
  @@index([githubInstallationId])
  @@index([githubRepositoryId])
  @@index([processStatus])
}

enum SupportTicketDepartment {
  BILLING
  TECHNICAL
  ACCOUNT
  COMPLIANCE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketService {
  AUTH
  BILLING
  DEPLOY
  DOMAINS
  INTEGRATIONS
  DATA
  OTHER
}

enum SupportTicketAttachmentUploadTarget {
  CREATE
  REPLY
}

enum BillingAccountStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAUSED
  CANCELED
  ENDED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
  CUSTOM
}

enum MeterAggregation {
  SUM
  MAX
  LAST
  COUNT
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum InvoiceLineType {
  SUBSCRIPTION
  METERED
  ADJUSTMENT
  TAX
  CREDIT
}

enum InvoiceLineSourceType {
  RATED_USAGE
  ADJUSTMENT
  MANUAL
}

enum BillingAdjustmentType {
  CREDIT
  DEBIT
  WRITEOFF
}

enum BillingRunType {
  RATING
  INVOICING
  FINALIZATION
  RECONCILIATION
}

enum BillingRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum BillingAuditAction {
  CREATED
  UPDATED
  DELETED
  RUN_STARTED
  RUN_FINISHED
  INVOICE_GENERATED
}

enum BillingActorType {
  SYSTEM
  USER
  WORKER
}

model SupportTicket {
  id                        String                  @id @default(cuid())
  ticketNumber              String                  @unique
  organizationId            String
  requesterWorkosUserId     String
  assignedAgentWorkosUserId String?
  department                SupportTicketDepartment
  priority                  SupportTicketPriority
  service                   SupportTicketService?
  status                    SupportTicketStatus     @default(OPEN)
  subject                   String
  description               String?
  secureForm                String?
  attachmentsJson           Json?
  resolvedAt                DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  replies                SupportTicketReply[]
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketConsumedSessions")

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, status])
  @@index([requesterWorkosUserId])
  @@index([assignedAgentWorkosUserId])
  @@index([department])
}

model SupportTicketReply {
  id                 String   @id @default(cuid())
  ticketId           String
  authorWorkosUserId String
  body               String
  secureForm         String?
  isInternalNote     Boolean  @default(false)
  attachmentsJson    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ticket                 SupportTicket                        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  consumedUploadSessions SupportTicketAttachmentUploadSession[] @relation("SupportTicketReplyConsumedSessions")

  @@index([ticketId, createdAt])
  @@index([authorWorkosUserId])
  @@index([isInternalNote])
}

model SupportTicketAttachmentUploadSession {
  id                 String                              @id
  organizationId     String
  uploaderWorkosUserId String
  target             SupportTicketAttachmentUploadTarget
  ticketId           String?
  fileName           String
  mimeType           String
  sizeBytes          Int
  checksumSha256     String?
  storageKey         String
  storageBucket      String
  expiresAt          DateTime
  registeredAt       DateTime?
  consumedAt         DateTime?
  consumedTicketId   String?
  consumedReplyId    String?
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt
  consumedTicket     SupportTicket?                      @relation("SupportTicketConsumedSessions", fields: [consumedTicketId], references: [id], onDelete: SetNull)
  consumedReply      SupportTicketReply?                 @relation("SupportTicketReplyConsumedSessions", fields: [consumedReplyId], references: [id], onDelete: SetNull)

  @@index([organizationId, uploaderWorkosUserId])
  @@index([target, ticketId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model BillingAccount {
  id             String               @id @default(cuid())
  organizationId String               @unique
  currency       String               @default("USD")
  timezone       String               @default("UTC")
  status         BillingAccountStatus @default(ACTIVE)
  metadataJson   Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  subscriptions   BillingSubscription[]
  usageEvents     UsageEvent[]
  ratedUsage      RatedUsage[]
  invoices        Invoice[]
  adjustments     BillingAdjustment[]
  runs            BillingRun[]
  auditLogs       BillingAuditLog[]
}

model BillingSubscription {
  id               String                    @id @default(cuid())
  billingAccountId String
  externalKey      String?
  status           BillingSubscriptionStatus @default(TRIALING)
  startedAt        DateTime
  canceledAt       DateTime?
  endedAt          DateTime?
  metadataJson     Json?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  versions       SubscriptionVersion[]
  usageEvents    UsageEvent[]
  invoices       Invoice[]

  @@unique([billingAccountId, externalKey])
  @@index([billingAccountId, status])
}

model SubscriptionVersion {
  id              String   @id @default(cuid())
  subscriptionId  String
  planVersionId   String
  version         Int
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  quantity        Decimal  @default(1) @db.Decimal(18, 6)
  metadataJson    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  planVersion  PlanVersion         @relation(fields: [planVersionId], references: [id], onDelete: Restrict)
  ratedUsage   RatedUsage[]

  @@unique([subscriptionId, version])
  @@index([subscriptionId, effectiveFrom(sort: Desc)])
  @@index([planVersionId])
}

model Plan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  metadataJson Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions PlanVersion[]
}

model PlanVersion {
  id            String        @id @default(cuid())
  planId        String
  version       Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  billingPeriod BillingPeriod
  metadataJson  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  plan                 Plan                  @relation(fields: [planId], references: [id], onDelete: Cascade)
  subscriptionVersions SubscriptionVersion[]
  meterPrices          MeterPrice[]

  @@unique([planId, version])
  @@index([planId, effectiveFrom(sort: Desc)])
}

model Meter {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  eventName    String
  valueKey     String?
  aggregation  MeterAggregation
  isActive     Boolean          @default(true)
  metadataJson Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  meterPrices MeterPrice[]
  usageEvents UsageEvent[]

  @@index([eventName])
}

model MeterPrice {
  id            String   @id @default(cuid())
  meterId        String
  planVersionId  String
  currency       String   @default("USD")
  unitPrice      Decimal  @db.Decimal(18, 6)
  includedUnits  Decimal  @default(0) @db.Decimal(18, 6)
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meter       Meter       @relation(fields: [meterId], references: [id], onDelete: Cascade)
  planVersion PlanVersion @relation(fields: [planVersionId], references: [id], onDelete: Cascade)
  ratedUsage  RatedUsage[]

  @@unique([meterId, planVersionId, effectiveFrom])
  @@index([meterId, planVersionId])
}

model UsageEvent {
  id             String   @id @default(cuid())
  billingAccountId String
  subscriptionId String?
  meterId        String
  eventTimestamp DateTime
  quantity       Decimal  @db.Decimal(18, 6)
  idempotencyKey String
  source         String?
  externalEventId String?
  payloadJson    Json?
  createdAt      DateTime @default(now())

  billingAccount BillingAccount        @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription   BillingSubscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  meter          Meter                 @relation(fields: [meterId], references: [id], onDelete: Restrict)
  ratedUsage     RatedUsage?

  @@unique([billingAccountId, idempotencyKey])
  @@index([billingAccountId, eventTimestamp])
  @@index([subscriptionId, meterId, eventTimestamp])
  @@index([meterId, eventTimestamp])
}

model RatedUsage {
  id                    String   @id @default(cuid())
  usageEventId          String   @unique
  billingAccountId      String
  subscriptionVersionId String?
  meterPriceId          String?
  invoiceLineId         String?
  quantity              Decimal  @db.Decimal(18, 6)
  unitPrice             Decimal  @db.Decimal(18, 6)
  amount                Decimal  @db.Decimal(18, 6)
  currency              String
  ratedAt               DateTime @default(now())
  createdAt             DateTime @default(now())

  usageEvent          UsageEvent            @relation(fields: [usageEventId], references: [id], onDelete: Cascade)
  billingAccount      BillingAccount        @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscriptionVersion SubscriptionVersion?  @relation(fields: [subscriptionVersionId], references: [id], onDelete: SetNull)
  meterPrice          MeterPrice?           @relation(fields: [meterPriceId], references: [id], onDelete: SetNull)
  invoiceLine         InvoiceLine?          @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, ratedAt])
  @@index([invoiceLineId])
  @@index([subscriptionVersionId])
}

model Invoice {
  id              String        @id @default(cuid())
  billingAccountId String
  subscriptionId  String?
  billingRunId    String?
  invoiceNumber   String        @unique
  periodStart     DateTime
  periodEnd       DateTime
  currency        String
  status          InvoiceStatus @default(DRAFT)
  subtotalAmount  Decimal       @default(0) @db.Decimal(18, 6)
  taxAmount       Decimal       @default(0) @db.Decimal(18, 6)
  discountAmount  Decimal       @default(0) @db.Decimal(18, 6)
  totalAmount     Decimal       @default(0) @db.Decimal(18, 6)
  issuedAt        DateTime?
  dueAt           DateTime?
  paidAt          DateTime?
  metadataJson    Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  billingAccount BillingAccount       @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  subscription   BillingSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  billingRun     BillingRun?          @relation(fields: [billingRunId], references: [id], onDelete: SetNull)
  lines          InvoiceLine[]
  adjustments    BillingAdjustment[]

  @@unique([billingAccountId, periodStart, periodEnd])
  @@index([billingAccountId, status])
  @@index([subscriptionId, periodStart])
  @@index([billingRunId])
}

model InvoiceLine {
  id            String          @id @default(cuid())
  invoiceId      String
  lineType       InvoiceLineType
  description    String
  quantity       Decimal         @db.Decimal(18, 6)
  unitPrice      Decimal         @db.Decimal(18, 6)
  amount         Decimal         @db.Decimal(18, 6)
  currency       String
  periodStart    DateTime?
  periodEnd      DateTime?
  metadataJson   Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  invoice     Invoice             @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sources     InvoiceLineSource[]
  ratedUsage  RatedUsage[]

  @@index([invoiceId])
  @@index([lineType])
}

model InvoiceLineSource {
  id             String                @id @default(cuid())
  invoiceLineId  String
  sourceType     InvoiceLineSourceType
  sourceId       String
  amount         Decimal               @db.Decimal(18, 6)
  metadataJson   Json?
  createdAt      DateTime              @default(now())

  invoiceLine InvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)

  @@unique([invoiceLineId, sourceType, sourceId])
  @@index([sourceType, sourceId])
}

model BillingAdjustment {
  id                  String               @id @default(cuid())
  billingAccountId    String
  invoiceId           String?
  adjustmentType      BillingAdjustmentType
  amount              Decimal              @db.Decimal(18, 6)
  currency            String
  reason              String?
  createdByWorkosUserId String?
  appliedAt           DateTime?
  metadataJson        Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, createdAt(sort: Desc)])
  @@index([invoiceId])
}

model BillingRun {
  id               String           @id @default(cuid())
  billingAccountId String?
  runType          BillingRunType
  periodStart      DateTime
  periodEnd        DateTime
  status           BillingRunStatus @default(PENDING)
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  errorMessage     String?
  metadataJson     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  billingAccount BillingAccount? @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
  auditLogs      BillingAuditLog[]

  @@unique([billingAccountId, runType, periodStart, periodEnd])
  @@index([billingAccountId, runType, startedAt(sort: Desc)])
}

model BillingAuditLog {
  id               String            @id @default(cuid())
  billingAccountId String?
  billingRunId     String?
  entityType       String
  entityId         String
  action           BillingAuditAction
  actorType        BillingActorType
  actorId          String?
  contextJson      Json?
  createdAt        DateTime          @default(now())

  billingAccount BillingAccount? @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)
  billingRun     BillingRun?     @relation(fields: [billingRunId], references: [id], onDelete: SetNull)

  @@index([billingAccountId, createdAt(sort: Desc)])
  @@index([billingRunId, createdAt])
  @@index([entityType, entityId])
}
